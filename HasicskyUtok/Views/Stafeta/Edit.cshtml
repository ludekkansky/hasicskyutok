@model HasicskyUtok.Models.Stafeta

@{
    ViewData["Title"] = "Upravit";
}

<h1>Úprava</h1>

<h4>Stafeta</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ID" />
            <div class="form-group">
                <label asp-for="NazevStafety" class="control-label"></label>
                <input asp-for="NazevStafety" class="form-control" />
                <span asp-validation-for="NazevStafety" class="text-danger"></span>

                <label asp-for="DoFinale" class="control-label"></label>
                @Html.CheckBoxFor(s=>Model.DoFinale,new {htmlAttributes = new { @class="from-check-input"}})
            </div>
            <div class="form-group">
                <input type="submit" value="Uložit" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">zpět na seznam</a>
</div>

